# Environment Configuration
NODE_ENV=development

# Database Configuration
VITE_DB_NAME=gnoseon.db
VITE_DB_PATH=./data

# Logging Configuration
VITE_LOG_LEVEL=info
VITE_LOG_TO_CONSOLE=true

# Application Configuration
VITE_APP_NAME=Gnōseōn
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Secure Messaging Application

# Security Configuration
VITE_ENCRYPTION_ENABLED=true
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/*,application/pdf,text/*

# Feature Flags
VITE_ENABLE_GROUP_CHATS=true
VITE_ENABLE_FILE_SHARING=true
VITE_ENABLE_VOICE_MESSAGES=false
VITE_ENABLE_VIDEO_CALLS=false

# UI Configuration
VITE_DEFAULT_THEME=light
VITE_DEFAULT_LANGUAGE=en
VITE_ENABLE_ANIMATIONS=true

# Development Configuration
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_HOST=localhost

# Production Configuration
VITE_PROD_SERVER_PORT=3000
VITE_ENABLE_HTTPS=false

# Monitoring and Analytics
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_ID=
VITE_ENABLE_ERROR_REPORTING=false
VITE_ERROR_REPORTING_ENDPOINT=

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000

# Notification Configuration
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_SOUND_NOTIFICATIONS=true
VITE_NOTIFICATION_SOUND=default

# Performance Configuration
VITE_ENABLE_LAZY_LOADING=true
VITE_ENABLE_VIRTUALIZATION=false
VITE_CACHE_ENABLED=true
